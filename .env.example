# Variáveis de Ambiente — BRAYO-WIKI
# Copie este arquivo para '.env' e preencha os valores
# NUNCA comite o arquivo '.env' — ele está no .gitignore

# ─────────────────────────────────────────────────────────────
# Flask
# ─────────────────────────────────────────────────────────────

# Chave secreta para assinar cookies e sessões (RBAC futuro)
# Gere um valor seguro com: python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=troque-por-uma-chave-segura-gerada-aleatoriamente

# Habilita o modo debug com hot-reload e Werkzeug Debugger
# NUNCA defina como 'true' em produção
FLASK_DEBUG=true

# Caminho absoluto para o vault de notas do Obsidian
# Deixe em branco para usar o vault de exemplo incluído no repositório (WikiVaultExample/)
# Exemplos:
#   Windows: C:\Users\SeuNome\Documents\ObsidianVault
#   Linux:   /home/seunome/ObsidianVault
VAULT_DIR=

# ─────────────────────────────────────────────────────────────
# Webhook GitHub (sincronização automática do vault)
# ─────────────────────────────────────────────────────────────

# Secret configurado em: GitHub → Repo → Settings → Webhooks → Secret
# Usado para validar a assinatura HMAC-SHA256 do payload
# Deixe vazio para desabilitar a validação (não recomendado em produção)
GITHUB_WEBHOOK_SECRET=
